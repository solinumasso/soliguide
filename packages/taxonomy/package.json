{
  "name": "@soliguide/taxonomy",
  "version": "4.137.1",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "generate-icons": "tsx scripts/icons-generator/index.ts",
    "check-icons": "tsx scripts/icons-generator/check-icons.ts",
    "generate:caddy": "tsx scripts/caddy/generate-caddy.ts",
    "generate:md": "tsx scripts/caddy/generate-md.ts",
    "copy-png-to-api": "mkdir -p ../api/resources/auto-export/pictos && cp -r icons/png/* ../api/resources/auto-export/pictos/",
    "copy-fonts-to-frontend": "mkdir -p ../frontend/src/assets/fonts/icons/ && cp fonts/categories-icons.woff fonts/categories-icons.woff2 fonts/categories-icons.scss ../frontend/src/assets/fonts/icons/",
    "copy-fonts-to-webapp": "mkdir -p ../web-app/src/assets/fonts/icons/ && cp fonts/categories-icons.woff fonts/categories-icons.woff2 ../web-app/src/assets/fonts/icons/",
    "copy-all": "yarn copy-png-to-api && yarn copy-fonts-to-frontend && yarn copy-fonts-to-webapp",
    "icons-full-process": "yarn generate-icons && yarn copy-all && echo '✅ Icons générés et copiés avec succès!'"
  },
  "dependencies": {
    "@soliguide/common": "workspace:*",
    "chalk": "^5.4.1",
    "fs-extra": "^11.3.0",
    "ora": "^8.2.0",
    "sharp": "^0.34.5",
    "svgtofont": "^6.5.1",
    "yaml": "^2.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.11",
    "@types/sharp": "^0.32.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-promise": "^7.1.0",
    "globals": "^16.1.0",
    "lint-staged": "^15.5.1",
    "ng-lint-staged": "^12.0.4",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0",
    "vitest": "^4.0.18"
  }
}
