
load(`${__dirname}/utils.mongodb`);

const anonymizeMails = async () =>
  await updateMany(db.mails, "mails user data", {}, [
    {
      $set: {
        recipientEmail: {
          $concat: ["email.", "$campaign", ".", "$mailType", "@email.com"],
        },
        "message.params.firstName": {
          $concat: ["Firstname Lastname ", "$campaign", " ", "$mailType"],
        },
      },
    },
  ]);
