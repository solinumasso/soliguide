{
  "name": "@soliguide/public-api",
  "version": "4.128.0",
  "description": "",
  "author": "",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --cache -c .",
    "format:fix": "prettier --cache -w .",
    "start": "nest start",
    "watch": "nest start --watch",
    "start:dev": "yarn watch",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/main",
    "lint:fix": "eslint --cache ./src --fix",
    "lint": "eslint --cache ./src",
    "openapi:generate": "ts-node --transpile-only src/versioning-engine/open-api.generator.cli.ts",
    "test": "vitest run --testTimeout=15000",
    "test:watch": "vitest --testTimeout=15000",
    "test:cov": "vitest run --coverage --testTimeout=15000",
    "test:debug": "vitest --inspect-brk --no-file-parallelism --testTimeout=15000",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@scalar/nestjs-api-reference": "^1.1.8",
    "@soliguide/api": "workspace:*",
    "@soliguide/common": "workspace:*",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.3",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4",
    "webpack": "5.106.1"
  },
  "lint-staged": {
    "*": "prettier --cache --ignore-unknown -w",
    "*.{ts,js}": "eslint --cache --fix"
  }
}
