# Snippet for maintenance mode
(maintenance) {
	root * /srv
	file_server
	templates
	rewrite * /maintenance.html
}

# Snippet for main Soliguide redirection
(angular_frontend) {
	reverse_proxy {
		to {$ANGULAR_FRONTEND_PROXY_URL}
		# Mandatory for Clever Cloud
		header_up Host {upstream_hostport}
    header_up X-Forwarded-Http-Host {upstream_hostport}
		# Check whether Soliguide is up
		health_uri {$ANGULAR_FRONTEND_PROXY_URL}/index.html
    health_follow_redirects
	}
}
